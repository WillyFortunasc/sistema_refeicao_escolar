SECRET_KEY=troque-por-uma-chave-segura
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# Banco (padrão SQLite se não definir)
# DATABASE_URL=postgres://user:pass@localhost:5432/refeicao

CORS_ALLOWED_ORIGINS=http://localhost:5173

# Google OAuth2 — obtenha em console.cloud.google.com
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/google/callback/

# Domínios permitidos para login Google (ex: escola.gov.br,educacao.gov.br)
# Deixe vazio para aceitar qualquer domínio em desenvolvimento
GOOGLE_ALLOWED_DOMAINS=
